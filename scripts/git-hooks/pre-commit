#!/bin/sh
# 若暂存区包含除 changelog.md 以外的变更，则要求 changelog.md 一并被暂存且相对 HEAD 有内容差异。
# 跳过：SKIP_CHANGELOG=1 git commit；合并中的提交：存在 .git/MERGE_HEAD 时自动跳过。

CHANGELOG="changelog.md"

exec 1>&2

if [ -n "$SKIP_CHANGELOG" ]; then
	exit 0
fi

if [ -f .git/MERGE_HEAD ]; then
	exit 0
fi

STAGED=$(git diff --cached --name-only --diff-filter=ACMRTUXB)
if [ -z "$STAGED" ]; then
	exit 0
fi

NON_CL=$(printf '%s\n' "$STAGED" | grep -v "^${CHANGELOG}$" || true)
if [ -z "$NON_CL" ]; then
	exit 0
fi

if ! printf '%s\n' "$STAGED" | grep -Fxq "$CHANGELOG"; then
	echo "提交被拒绝：除 ${CHANGELOG} 外还有已暂存文件，但未暂存 ${CHANGELOG}。"
	echo "请在本仓库根目录的 ${CHANGELOG} 中整理本次改动摘要，并执行: git add ${CHANGELOG}"
	echo "若确需跳过（不推荐）: SKIP_CHANGELOG=1 git commit"
	exit 1
fi

if git rev-parse --verify HEAD >/dev/null 2>&1; then
	if git diff --cached --quiet HEAD -- "$CHANGELOG"; then
		echo "提交被拒绝：${CHANGELOG} 已暂存，但与当前 HEAD 相比无内容变化。"
		echo "请追加本次改动的记录后再暂存并提交。"
		echo "若确需跳过（不推荐）: SKIP_CHANGELOG=1 git commit"
		exit 1
	fi
fi

exit 0
