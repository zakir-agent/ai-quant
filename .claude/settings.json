{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "./scripts/ci-check.sh all 2>&1",
            "statusMessage": "Running CI checks..."
          }
        ]
      }
    ]
  }
}
