# === 基础设施 ===
# PostgreSQL 连接串
# 本地开发: postgresql+asyncpg://aiquant:aiquant@localhost:5432/ai_quant
# Docker Compose: postgresql+asyncpg://aiquant:aiquant@postgres:5432/ai_quant
# Supabase: postgresql+asyncpg://postgres:password@db.xxx.supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://aiquant:aiquant@localhost:5432/ai_quant
DB_POOL_SIZE=5
DB_POOL_MAX_OVERFLOW=5
# Redis (可选，留空则使用内存缓存)
# 本地开发: redis://localhost:6379/0
# Upstash: rediss://default:xxx@xxx.upstash.io:6379
REDIS_URL=
# CORS 允许的前端域名 (逗号分隔)
# 本地开发: http://localhost:3000
# Render 部署: https://your-frontend.onrender.com,http://localhost:3000
CORS_ORIGINS=http://localhost:3000
# OHLCV 数据保留天数 (超过此天数的小时级数据将被聚合清理)
DATA_RETENTION_DAYS=90

# === AI 模型 ===
# 模型名使用 LiteLLM 格式，例如:
#   gpt-4o, gpt-4o-mini, gemini/gemini-2.5-flash, claude-sonnet-4-20250514
# 完整列表: https://docs.litellm.ai/docs/providers
# 默认：主模型走 OpenAI（付费），失败时再走 Gemini（免费层作备用）
AI_PRIMARY_MODEL=gpt-4o
AI_FALLBACK_MODEL=gemini/gemini-2.5-flash
AI_FAST_MODEL=gpt-4o-mini
AI_MAX_ANALYSES_PER_DAY=10
# 定时任务在每个 ANALYSIS_INTERVAL_HOURS 周期里，除了跑一次市场全局分析外
# 还会对下列 symbol 单独跑一次单币种深度分析（逗号分隔，留空表示只跑市场）
AI_ANALYSIS_SYMBOLS=

# 填写对应模型的 API Key（主路径建议填 OPENAI；备用填 GEMINI）
# LiteLLM 标准变量名: OPENAI_API_KEY, GEMINI_API_KEY, ANTHROPIC_API_KEY, OPENROUTER_API_KEY
OPENAI_API_KEY=
GEMINI_API_KEY=

# === 数据源 ===
BINANCE_API_KEY=
BINANCE_API_SECRET=
# CEX K 线采集：默认交易对与周期（逗号分隔，交易对为 ccxt 格式如 BTC/USDT）
CEX_DEFAULT_SYMBOLS=BTC/USDT,ETH/USDT,BTC/USDC,ETH/USDC,SOL/USDT,BNB/USDT
CEX_DEFAULT_TIMEFRAMES=1h,4h,1d
# CoinGecko 市场概览：逗号分隔的 CoinGecko coin ID（控制首页"市场概览"显示哪些币种）
# 完整 ID 列表: https://api.coingecko.com/api/v3/coins/list
COINGECKO_COIN_IDS=bitcoin,ethereum,solana,binancecoin,ripple,cardano,dogecoin,tron,chainlink,hyperliquid
# CoinGecko, DefiLlama, DexScreener, 新闻 RSS 免费 API 无需 Key
# NewsAPI.org（可选）：主流财经媒体源，用于情绪分析的补充
# 免费档限制：100 次/天、文章延迟 24 小时；留空则不启用
# 申请地址：https://newsapi.org/register
NEWSAPI_KEY=
NEWSAPI_QUERY=bitcoin OR ethereum OR crypto OR cryptocurrency
NEWSAPI_LANGUAGE=en

# === 网络与重试 ===
# HTTP 请求默认超时（秒），各 collector 统一使用
HTTP_TIMEOUT_DEFAULT=15
# HTTP 请求最大重试次数
HTTP_MAX_RETRIES=3

# === 数据库连接池 ===
# 连接回收时间（秒）
DB_POOL_RECYCLE_SECONDS=300

# === 缓存 ===
# cache_set() 默认 TTL（秒）
CACHE_DEFAULT_TTL_SECONDS=600

# === Binance 合约 ===
BINANCE_FUTURES_BASE_URL=https://fapi.binance.com
# USDT-M 永续合约跟踪的币对（逗号分隔）
BINANCE_FUTURES_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT
# API 请求间隔（秒），避免限流
BINANCE_RATE_LIMIT_DELAY=0.2

# === Binance WebSocket ===
BINANCE_WS_BASE_URL=wss://stream.binance.com:9443/stream
# WS 订阅的 K 线周期（逗号分隔）
BINANCE_WS_TIMEFRAMES=1m,1h
BINANCE_WS_PING_INTERVAL=20
BINANCE_WS_RECONNECT_DELAY=5

# === DexScreener ===
DEXSCREENER_BASE_URL=https://api.dexscreener.com
# 搜索的交易对（逗号分隔）
DEXSCREENER_SEARCH_QUERIES=WETH USDC,WBTC USDC,SOL USDC,PEPE WETH,ARB WETH

# === Fear & Greed Index ===
FEAR_GREED_API_URL=https://api.alternative.me/fng/?limit=1&format=json
# 缓存 TTL（秒）
FEAR_GREED_CACHE_TTL=3600

# === 新闻 RSS 源 ===
# 格式："name|url" 逗号分隔；修改此项即可增删 RSS 源
NEWS_RSS_FEEDS=coindesk|https://www.coindesk.com/arc/outboundfeeds/rss/,cointelegraph|https://cointelegraph.com/rss,theblock|https://www.theblock.co/rss.xml,decrypt|https://decrypt.co/feed,bitcoinmagazine|https://bitcoinmagazine.com/feed,newsbtc|https://www.newsbtc.com/feed/,cryptoslate|https://cryptoslate.com/feed/,beincrypto|https://beincrypto.com/feed/

# === 市场概览 ===
# data_aggregator 市场全局快照使用的币对（ccxt 格式，逗号分隔）
MARKET_OVERVIEW_PAIRS=BTC/USDT,ETH/USDT,SOL/USDT,BNB/USDT

# === 准确率追踪 ===
# AI 推荐评估窗口（小时），评估推荐发出后 N 小时的价格变动
ACCURACY_EVAL_WINDOW_HOURS=24

# === 采集调度 ===
COLLECT_INTERVAL_MINUTES=30
NEWS_COLLECT_INTERVAL_MINUTES=15
# NewsAPI 走小时级调度，确保不超过 100 次/天的免费配额
NEWSAPI_COLLECT_INTERVAL_HOURS=12
ANALYSIS_INTERVAL_HOURS=4
# Fear & Greed 采集间隔（小时）
FEAR_GREED_INTERVAL_HOURS=1
# AI 准确率评分间隔（小时）
ACCURACY_INTERVAL_HOURS=6
# 数据保留清理间隔（小时）
DATA_RETENTION_INTERVAL_HOURS=24
SCHEDULER_JOB_TIMEOUT_SECONDS=120

# === 告警/通知（Telegram Bot + Webhook）===
# 总开关：false 则不发送任何通知
ALERT_ENABLED=true
# Telegram 推送（两者都填才会发送）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# 可选：通用 Webhook（可对接 Slack/Discord/钉钉等）
ALERT_WEBHOOK_URL=
# 告警阈值与冷却
ALERT_PRICE_CHANGE_PCT=5.0
ALERT_SENTIMENT_DELTA=30
ALERT_COOLDOWN_MINUTES=30
